{
  "name": "ui-kit-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run start:showcase",
    "start:showcase": "ng serve showcase",
    "build": "npm run build:ui-kit && npm run build:showcase",
    "build:ui-kit": "ng build ui-kit",
    "build:showcase": "ng build showcase",
    "watch": "ng build showcase --watch --configuration development",
    "test:ui-kit": "vitest run projects/ui-kit/src/lib/core/class-variants.spec.ts"
  },
  "private": true,
  "packageManager": "npm@10.9.7",
  "dependencies": {
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "flatpickr": "^4.6.13",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.2.3",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
